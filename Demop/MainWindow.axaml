<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Icon="avares://Demop/Assets/Icons/Icon.ico"
        FontFamily="Times New Roman"
        FontSize="18"
        x:Class="Demop.MainWindow"
        Title="ООО ОБУВЬ">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="5"></RowDefinition>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Height="100" Width="100" VerticalAlignment="Top" Source="avares://Demop/Assets/Icons/Icon.ico"/>
            <TextBlock Name="userFIO" HorizontalAlignment="Right"/>
            <Button Name="LogoutButton" Content="Выход" Click="LogoutButton_OnClick"/>
            </StackPanel>
                    
            <ContentControl Grid.Row="0" Name="MainContentControl"></ContentControl>


        </Grid>
</Window>
